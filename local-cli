#!/usr/bin/env bash
set -euo pipefail

CONN_INFO="${XDG_CONFIG_HOME:-$HOME/.config}/Local/graphql-connection-info.json"

if [[ ! -f "$CONN_INFO" ]]; then
  echo "Error: Local is not running (connection info not found)" >&2
  exit 1
fi

PORT=$(jq -r '.port' "$CONN_INFO")
TOKEN=$(jq -r '.authToken' "$CONN_INFO")
URL="http://127.0.0.1:${PORT}/graphql"

graphql() {
  curl -sf -X POST "$URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $TOKEN" \
    -d "$1"
}

list_sites() {
  graphql '{"query":"{ sites { id name status } }"}' | \
    jq -r '.data.sites[] | "\(.id)\t\(.name)\t\(.status)"'
}

start_site() {
  local id=$1
  graphql "{\"query\":\"mutation { startSite(id: \\\"$id\\\") { name status } }\"}" | \
    jq -r '.data.startSite | "\(.name) → \(.status)"'
}

stop_site() {
  local id=$1
  graphql "{\"query\":\"mutation { stopSite(id: \\\"$id\\\") { name status } }\"}" | \
    jq -r '.data.stopSite | "\(.name) → \(.status)"'
}

stop_all() {
  list_sites | awk -F'\t' '$3=="running" {print $1}' | while read -r id; do
    stop_site "$id"
  done
}

SITES_JSON="${XDG_CONFIG_HOME:-$HOME/.config}/Local/sites.json"

# Find Local site by theme path
find_site_by_path() {
  local theme_path
  theme_path=$(realpath "${1:-$PWD}")

  if [[ ! -f "$SITES_JSON" ]]; then
    echo "Error: sites.json not found" >&2
    exit 1
  fi

  jq -r 'to_entries[] | "\(.key)\t\(.value.name)\t\(.value.path)"' "$SITES_JSON" | \
    while IFS=$'\t' read -r id name path; do
      if [[ "$theme_path" == "$path"* ]]; then
        echo "$id"$'\t'"$name"
        return
      fi
    done
}

theme_toggle() {
  local dir="${1:-$PWD}"

  if [[ ! -f "$dir/functions.php" || ! -f "$dir/style.css" ]]; then
    echo "Error: not a WordPress theme directory (missing functions.php or style.css)" >&2
    exit 1
  fi

  local match
  match=$(find_site_by_path "$dir")

  if [[ -z "$match" ]]; then
    echo "Error: could not find a Local site containing this theme path" >&2
    exit 1
  fi

  local id name status
  id=$(echo "$match" | cut -f1)
  name=$(echo "$match" | cut -f2)
  status=$(list_sites | awk -F'\t' -v id="$id" '$1==id {print $3}')

  echo "Site:   $name"
  echo "Status: $status"
  echo ""

  case "$status" in
    running)
      read -r -p "Stop site? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] && stop_site "$id"
      ;;
    halted)
      read -r -p "Start site? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] && start_site "$id"
      ;;
    *)
      echo "Unknown status: $status" >&2
      exit 1
      ;;
  esac
}

# Pick site via fzf
pick_site() {
  local result
  result=$({ echo "exit"; list_sites | column -t -s $'\t'; } | \
    fzf --prompt="site> " --height=40% --reverse)
  [[ -z "$result" || "$result" == "exit" ]] && exit 0
  echo "$result" | awk '{print $1}'
}

case "${1:-}" in
  help|-h|--help)
    echo "Usage: local-cli <command>"
    echo ""
    echo "Commands:"
    echo "  (none)        interactive mode: pick site and action via fzf"
    echo "  list          list all sites"
    echo "  running       list running sites"
    echo "  start         pick site via fzf and start it"
    echo "  stop          pick site via fzf and stop it"
    echo "  stop-all      stop all running sites"
    echo "  theme [path]  detect site from theme dir and toggle start/stop"
    echo "  install       symlink local-cli to ~/.local/bin (or custom dir)"
    echo "  help          show this help"
    ;;
  install)
    INSTALL_DIR="${2:-$HOME/.local/bin}"
    mkdir -p "$INSTALL_DIR"
    ln -sf "$(realpath "$0")" "$INSTALL_DIR/local-cli"
    echo "Linked: $INSTALL_DIR/local-cli → $(realpath "$0")"
    echo "Make sure $INSTALL_DIR is in your PATH"
    ;;
  start)
    id=$(pick_site)
    [[ -z "$id" ]] && exit 0
    start_site "$id"
    ;;
  stop)
    id=$(pick_site)
    [[ -z "$id" ]] && exit 0
    stop_site "$id"
    ;;
  stop-all)
    stop_all
    ;;
  theme)
    theme_toggle "${2:-}"
    ;;
  list)
    list_sites | column -t -s $'\t'
    ;;
  running)
    list_sites | awk -F'\t' '$3=="running"' | column -t -s $'\t'
    ;;
  *)
    # Интерактивный режим — выбрать сайт, потом действие
    id=$(pick_site)
    [[ -z "$id" ]] && exit 0

    action=$(printf 'start\nstop\nexit' | fzf --prompt="action> " --height=15% --reverse)
    case "$action" in
      start) start_site "$id" ;;
      stop)  stop_site  "$id" ;;
      exit)  exit 0 ;;
    esac
    ;;
esac
