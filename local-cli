#!/usr/bin/env bash
set -euo pipefail

CONN_INFO="${XDG_CONFIG_HOME:-$HOME/.config}/Local/graphql-connection-info.json"
SITES_JSON="${XDG_CONFIG_HOME:-$HOME/.config}/Local/sites.json"

if [[ ! -f "$CONN_INFO" ]]; then
  echo "Error: Local is not running (connection info not found)" >&2
  exit 1
fi

PORT=$(jq -r '.port' "$CONN_INFO")
TOKEN=$(jq -r '.authToken' "$CONN_INFO")
URL="http://127.0.0.1:${PORT}/graphql"

graphql() {
  curl -sf -X POST "$URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $TOKEN" \
    -d "$1"
}

list_sites() {
  graphql '{"query":"{ sites { id name status } }"}' | \
    jq -r '.data.sites[] | "\(.id)\t\(.name)\t\(.status)"'
}

start_site() {
  local id=$1
  graphql "{\"query\":\"mutation { startSite(id: \\\"$id\\\") { name status } }\"}" | \
    jq -r '.data.startSite | "\(.name) → \(.status)"'
}

stop_site() {
  local id=$1
  graphql "{\"query\":\"mutation { stopSite(id: \\\"$id\\\") { name status } }\"}" | \
    jq -r '.data.stopSite | "\(.name) → \(.status)"'
}

stop_all() {
  local running
  running=$(list_sites | awk -F'\t' '$3=="running" {print $1}')
  if [[ -z "$running" ]]; then
    echo "No running sites."
    return
  fi
  echo "$running" | while read -r id; do
    stop_site "$id"
  done
}

find_site_by_path() {
  local theme_path
  theme_path=$(realpath "${1:-$PWD}")

  echo "[debug] theme_path: $theme_path" >&2
  echo "[debug] sites.json: $SITES_JSON" >&2

  jq -r 'to_entries[] | "\(.key)\t\(.value.name)\t\(.value.path)"' "$SITES_JSON" | \
    while IFS=$'\t' read -r id name path; do
      echo "[debug] checking site '$name' → path: '$path'" >&2
      if [[ "$theme_path" == "$path"* ]]; then
        echo "[debug] MATCH found: $id $name" >&2
        echo "$id"$'\t'"$name"
        return
      fi
    done
}

theme_toggle() {
  local dir="${1:-$PWD}"

  if [[ ! -f "$dir/functions.php" || ! -f "$dir/style.css" ]]; then
    echo "Error: not a WordPress theme directory (missing functions.php or style.css)" >&2
    exit 1
  fi

  local match
  match=$(find_site_by_path "$dir")

  if [[ -z "$match" ]]; then
    echo "Error: could not find a Local site for this theme path" >&2
    exit 1
  fi

  local id name status
  id=$(echo "$match" | cut -f1)
  name=$(echo "$match" | cut -f2)
  status=$(list_sites | awk -F'\t' -v id="$id" '$1==id {print $3}')

  echo "Site:   $name"
  echo "Status: $status"
  echo ""

  case "$status" in
    running)
      read -r -p "Stop site? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] && stop_site "$id"
      ;;
    halted)
      read -r -p "Start site? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] && start_site "$id"
      ;;
  esac
}

interactive() {
  # Show running sites
  local running
  running=$(list_sites | awk -F'\t' '$3=="running"')

  if [[ -n "$running" ]]; then
    echo "Running sites:"
    echo "$running" | column -t -s $'\t'
    echo ""
  else
    echo "No running sites."
    echo ""
  fi

  # Pick action
  local action
  action=$(printf 'Start\nStop\nStop All\nTheme toggle\nInstall\nExit' | \
    fzf --prompt="action> " --height=25% --reverse)

  case "$action" in
    Start)
      local result
      result=$({ echo "← back"; list_sites | column -t -s $'\t'; } | \
        fzf --prompt="start site> " --height=40% --reverse)
      [[ -z "$result" || "$result" == "← back" ]] && exit 0
      start_site "$(echo "$result" | awk '{print $1}')"
      ;;
    Stop)
      if [[ -z "$running" ]]; then
        echo "No running sites to stop."
        exit 0
      fi
      local result
      result=$({ echo "← back"; echo "$running" | column -t -s $'\t'; } | \
        fzf --prompt="stop site> " --height=40% --reverse)
      [[ -z "$result" || "$result" == "← back" ]] && exit 0
      stop_site "$(echo "$result" | awk '{print $1}')"
      ;;
    "Stop All")
      stop_all
      ;;
    "Theme toggle")
      theme_toggle
      ;;
    Install)
      local install_dir="$HOME/.local/bin"
      mkdir -p "$install_dir"
      ln -sf "$(realpath "$0")" "$install_dir/local-cli"
      echo "Linked: $install_dir/local-cli → $(realpath "$0")"
      ;;
    Exit|"")
      exit 0
      ;;
  esac
}

case "${1:-}" in
  theme)
    theme_toggle "${2:-}"
    ;;
  install)
    INSTALL_DIR="${2:-$HOME/.local/bin}"
    mkdir -p "$INSTALL_DIR"
    ln -sf "$(realpath "$0")" "$INSTALL_DIR/local-cli"
    echo "Linked: $INSTALL_DIR/local-cli → $(realpath "$0")"
    echo "Make sure $INSTALL_DIR is in your PATH"
    ;;
  help|-h|--help)
    echo "Usage: local-cli [command]"
    echo ""
    echo "Commands:"
    echo "  (none)        interactive mode"
    echo "  theme [path]  detect site from theme dir and toggle start/stop"
    echo "  install       symlink local-cli to ~/.local/bin (or custom dir)"
    echo "  help          show this help"
    ;;
  *)
    interactive
    ;;
esac
